{
  "name": "cognimesh-bios",
  "version": "5.0.0",
  "description": "BIOS - Basic Input/Output System for CogniMesh Multi-Agent Orchestration",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "node scripts/run-build.js",
    "brand:generate": "node scripts/generate-brand-assets.js",
    "server": "node src/server.js",
    "bios:boot": "node src/bios/cli.js boot",
    "bios:diagnose": "node src/bios/cli.js diagnose",
    "bios:maintenance": "node src/bios/cli.js maintenance",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node scripts/run-node-tests.js tests/unit .test.js",
    "test:integration": "node scripts/run-node-tests.js tests/domains .spec.js",
    "test:e2e": "node scripts/run-node-tests.js tests/e2e .spec.js",
    "test:watch": "node scripts/run-node-tests.js tests/unit .test.js --watch",
    "test:coverage": "npx c8 node --test tests/unit/**/*.test.js",
    "test:full": "npm run verify:release && npm run verify:security",
    "verify:static": "eslint src/",
    "verify:unit": "npm run test:unit",
    "verify:integration": "npm run test:integration",
    "verify:provider-matrix": "node scripts/verify-provider-matrix.js",
    "verify:release": "npm run lint && npm run test:unit && npm run test:integration && npm run test:e2e && npm run verify:provider-matrix",
    "verify:performance": "node scripts/run-bios-performance.js",
    "verify:security": "npm audit && node src/security/audit-comprehensive.js",
    "test:bios:unit": "node scripts/run-bios-unit.js",
    "test:bios:integration": "node scripts/run-bios-integration.js",
    "test:bios:performance": "node scripts/run-bios-performance.js",
    "test:bios:security": "node scripts/run-bios-security.js",
    "test:bios:all": "npm run test:bios:unit && npm run test:bios:integration && npm run test:bios:performance && npm run test:bios:security",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js'",
    "db:migrate": "node scripts/migrate.js",
    "db:backup": "node src/db/backup.js create",
    "db:backup:restore": "node scripts/backup-restore.js",
    "db:backup:verify": "node scripts/backup-verify.js",
    "db:backup:schedule": "node src/db/backup-scheduler.js",
    "docs:generate": "npx jsdoc -c jsdoc.json"
  },
  "keywords": [
    "bios",
    "orchestration",
    "multi-agent",
    "cognimesh",
    "automation"
  ],
  "author": "CogniMesh Systems",
  "license": "MIT",
  "bin": {
    "cognimesh": "./src/bios/cli.js",
    "cm": "./src/bios/cli.js"
  },
  "files": [
    "src/",
    "config/",
    "scripts/",
    "README.md",
    "LICENSE",
    "API_REFERENCE.md",
    "ARCHITECTURE.md",
    "DEPLOYMENT.md"
  ],
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "blessed": "^0.1.81",
    "commander": "^12.0.0",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "octokit": "^3.1.2",
    "prom-client": "^15.1.0",
    "sqlite3": "^5.1.6",
    "winston": "^3.19.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
