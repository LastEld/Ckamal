{
  "templates": {
    "minimal": {
      "name": "Minimal CV",
      "description": "Clean and simple CV template",
      "structure": {
        "sections": [
          {
            "id": "header",
            "type": "header",
            "required": true,
            "fields": ["name", "email", "phone", "location"]
          },
          {
            "id": "summary",
            "type": "text",
            "required": false,
            "fields": ["summary"]
          },
          {
            "id": "experience",
            "type": "list",
            "required": true,
            "fields": ["company", "role", "startDate", "endDate", "description"]
          },
          {
            "id": "education",
            "type": "list",
            "required": true,
            "fields": ["institution", "degree", "graduationYear"]
          },
          {
            "id": "skills",
            "type": "tags",
            "required": false,
            "fields": ["skills"]
          }
        ]
      },
      "styling": {
        "font": "Arial",
        "fontSize": 11,
        "color": "#333333",
        "layout": "single-column"
      }
    },
    "professional": {
      "name": "Professional CV",
      "description": "Traditional professional CV format",
      "structure": {
        "sections": [
          {
            "id": "header",
            "type": "header",
            "required": true,
            "fields": ["name", "title", "email", "phone", "location", "linkedin"]
          },
          {
            "id": "summary",
            "type": "text",
            "required": true,
            "fields": ["summary"],
            "maxLength": 500
          },
          {
            "id": "experience",
            "type": "timeline",
            "required": true,
            "fields": ["company", "role", "location", "startDate", "endDate", "description", "achievements"]
          },
          {
            "id": "education",
            "type": "timeline",
            "required": true,
            "fields": ["institution", "degree", "field", "graduationYear", "gpa"]
          },
          {
            "id": "skills",
            "type": "categorized",
            "required": true,
            "fields": ["technical", "languages", "soft"]
          },
          {
            "id": "certifications",
            "type": "list",
            "required": false,
            "fields": ["name", "issuer", "date", "expiry"]
          },
          {
            "id": "projects",
            "type": "list",
            "required": false,
            "fields": ["name", "description", "technologies", "url"]
          }
        ]
      },
      "styling": {
        "font": "Georgia",
        "fontSize": 10.5,
        "color": "#2c3e50",
        "accentColor": "#3498db",
        "layout": "two-column"
      }
    },
    "modern": {
      "name": "Modern CV",
      "description": "Contemporary design with visual elements",
      "structure": {
        "sections": [
          {
            "id": "sidebar",
            "type": "sidebar",
            "required": true,
            "fields": ["photo", "name", "title", "contact", "skills", "languages", "interests"]
          },
          {
            "id": "main",
            "type": "main-content",
            "required": true,
            "subsections": [
              {
                "id": "profile",
                "type": "text",
                "fields": ["profile"]
              },
              {
                "id": "experience",
                "type": "cards",
                "fields": ["company", "role", "duration", "description", "highlights"]
              },
              {
                "id": "education",
                "type": "compact",
                "fields": ["institution", "degree", "year"]
              },
              {
                "id": "portfolio",
                "type": "grid",
                "fields": ["project", "link", "image"]
              }
            ]
          }
        ]
      },
      "styling": {
        "font": "Roboto",
        "fontSize": 10,
        "color": "#444444",
        "accentColor": "#e74c3c",
        "sidebarColor": "#2c3e50",
        "layout": "sidebar-left"
      }
    },
    "academic": {
      "name": "Academic CV",
      "description": "Comprehensive academic and research CV",
      "structure": {
        "sections": [
          {
            "id": "personal",
            "type": "header",
            "required": true,
            "fields": ["name", "title", "institution", "department", "email"]
          },
          {
            "id": "research-interests",
            "type": "text",
            "required": true,
            "fields": ["researchInterests"]
          },
          {
            "id": "education",
            "type": "detailed",
            "required": true,
            "fields": ["institution", "degree", "field", "year", "thesis", "advisor"]
          },
          {
            "id": "appointments",
            "type": "timeline",
            "required": true,
            "fields": ["position", "institution", "department", "startDate", "endDate"]
          },
          {
            "id": "publications",
            "type": "publications",
            "required": true,
            "fields": ["authors", "title", "journal", "year", "doi", "citations"]
          },
          {
            "id": "grants",
            "type": "funding",
            "required": false,
            "fields": ["title", "agency", "amount", "period", "role"]
          },
          {
            "id": "teaching",
            "type": "list",
            "required": false,
            "fields": ["course", "institution", "level", "year", "students"]
          },
          {
            "id": "service",
            "type": "list",
            "required": false,
            "fields": ["activity", "organization", "role", "year"]
          }
        ]
      },
      "styling": {
        "font": "Times New Roman",
        "fontSize": 11,
        "color": "#000000",
        "layout": "academic-standard"
      }
    }
  },
