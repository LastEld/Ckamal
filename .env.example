# ============================================================
# CogniMesh v5.0 - Environment Configuration Example
# ============================================================
# Copy this file to .env and fill in your actual values
# Never commit .env file with real credentials to version control
# ============================================================

# ============================================================
# Core System
# ============================================================

# Node environment: development | test | production
NODE_ENV=development

# Server configuration
COGNIMESH_PORT=3000
COGNIMESH_HOST=localhost
COGNIMESH_NAME=cognimesh-server

# Project root directory (optional, auto-detected if not set)
# COGNIMESH_ROOT=/path/to/cognimesh

# ============================================================
# Directory Paths (optional, relative to COGNIMESH_ROOT)
# ============================================================

COGNIMESH_DATA_DIR=./data
COGNIMESH_CACHE_DIR=./cache
COGNIMESH_LOGS_DIR=./logs

# State persistence path for BIOS
STATE_PATH=./state

# ============================================================
# Database (SQLite)
# ============================================================

DATABASE_PATH=./data/cognimesh.db
DATABASE_URL=sqlite:./data/cognimesh.db

# Connection pool settings
DB_MAX_CONNECTIONS=10
DB_BUSY_TIMEOUT_MS=5000
DB_MAX_RETRIES=5
DB_RETRY_DELAY_MS=200

# ============================================================
# GitHub Integration
# ============================================================

# GitHub Personal Access Token
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, workflow, read:org
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default GitHub repository (owner/repo format)
GITHUB_REPO=cognimesh/cognimesh

# Auto-update check interval (e.g., 1h, 30m, 24h)
CHECK_INTERVAL=1h

# ============================================================
# AI/LLM Configuration
# ============================================================
# NOTE: Direct API keys are NOT needed for subscription mode (the default).
# CogniMesh routes through local client surfaces (Claude Code, Kimi CLI,
# Codex CLI) which use your existing subscriptions. The API key variables
# below are only needed for testing or direct-API fallback mode.

# Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_key_here  # Not needed for subscription mode
ANTHROPIC_API_URL=https://api.anthropic.com/v1
CLAUDE_SESSION_TOKEN=your_claude_session_token_here
CLAUDE_ORGANIZATION_ID=your_claude_org_id_here
CLAUDE_DEFAULT_MODEL=claude-3-5-sonnet
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7
CLAUDE_STREAMING_ENABLED=true
CLAUDE_EXTENDED_THINKING_ENABLED=false

# Claude Vision-specific settings
CLAUDE_BASE_URL=https://claude.ai/api
CLAUDE_API_VERSION=2024-01-01
CLAUDE_VISION_MODEL=claude-3-5-sonnet-20241022

# Moonshot Kimi
# KIMI_API_KEY=your_kimi_key_here  # Not needed for subscription mode
KIMI_API_URL=https://api.moonshot.cn/v1
# MOONSHOT_API_KEY=your_moonshot_key_here  # Not needed for subscription mode

# OpenAI
# OPENAI_API_KEY=your_openai_key_here  # Not needed for subscription mode
OPENAI_API_URL=https://api.openai.com/v1

# GitHub Copilot (optional, falls back to GITHUB_TOKEN)
# GITHUB_COPILOT_TOKEN=your_github_copilot_token_here  # Not needed for subscription mode

# ============================================================
# BIOS System
# ============================================================

# Boot mode: BOOT | DIAGNOSE | OPERATIONAL | MAINTENANCE | SAFE_MODE
BIOS_MODE=OPERATIONAL

# Enable automatic subsystem updates
AUTO_UPDATE=true

# Maximum acceptable performance regression (%)
REGRESSION_THRESHOLD=5.0

# Maximum number of concurrent agents
MAX_AGENTS=50

# ============================================================
# WebSocket Server
# ============================================================

WS_ENABLED=true
WS_PORT=8080
WS_HOST=localhost
WS_PATH=/ws
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MAX_PAYLOAD_MB=50
WS_REQUIRE_AUTH=false
WS_CORS_ORIGIN=*
WS_MAX_STREAMS=100

# ============================================================
# Dashboard
# ============================================================

DASHBOARD_ENABLED=true
DASHBOARD_PORT=3001
DASHBOARD_HOST=0.0.0.0
DASHBOARD_AUTH_ENABLED=true

# Admin credentials (change in production!)
ADMIN_PASSWORD=admin

# ============================================================
# MCP (Model Context Protocol)
# ============================================================

MCP_IDLE_TIMEOUT_MS=0
MCP_PARENT_WATCH_INTERVAL_MS=10000
MCP_SERIALIZE_TOOL_CALLS=true

# ============================================================
# Cache Configuration
# ============================================================

CACHE_ENABLED=true
CACHE_MAX_SIZE=1000
CACHE_TTL_MS=60000
CACHE_CHECK_PERIOD_MS=120

# ============================================================
# Logging
# ============================================================

# Log level: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# Enable debug mode (verbose logging) - avoid in production
DEBUG=false

# ============================================================
# HashiCorp Vault Integration (SEC-001)
# ============================================================

# Enable Vault for secrets management
VAULT_ENABLED=false

# Vault server endpoint
VAULT_ADDR=http://localhost:8200

# Vault authentication token
# Get from: vault token create -policy=cognimesh
VAULT_TOKEN=

# Vault namespace (for Vault Enterprise)
# VAULT_NAMESPACE=cognimesh

# Vault secrets engine mount point
VAULT_MOUNT_POINT=secret

# Vault API version: v1 | v2 (KV v2 recommended)
VAULT_API_VERSION=v2

# Vault fallback: use env vars if Vault unavailable
VAULT_FALLBACK_ENABLED=true

# Vault cache: cache secrets locally (TTL in ms)
VAULT_CACHE_ENABLED=true
VAULT_CACHE_TTL=300000

# Vault paths for secrets (customizable)
# VAULT_PATH_ANTHROPIC=api/anthropic
# VAULT_PATH_KIMI=api/kimi
# VAULT_PATH_OPENAI=api/openai
# VAULT_PATH_GITHUB=auth/github
# VAULT_PATH_DATABASE=database/url
# VAULT_PATH_JWT=security/jwt

# ============================================================
# Security
# ============================================================

# Security mode: enforced | permissive
# In production, use 'enforced'
SECURITY_MODE=permissive

# Master JWT secret (min 32 characters, change in production!)
JWT_SECRET=your_jwt_secret_here_change_in_production_minimum_32_chars

# Session secret (min 32 characters)
SESSION_SECRET=your_session_secret_here_change_in_production_min_32

# Additional security pepper for hashing
SECURITY_PEPPER=your_security_pepper_here

# API Key header name
API_KEY_HEADER=X-API-Key

# Require authentication globally
REQUIRE_AUTH=false

# HTTPS enforcement (enable in production)
HTTPS_ONLY=false

# Security headers configured flag
SECURITY_HEADERS_CONFIGURED=false

# Rate limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Password policy
PASSWORD_MIN_LENGTH=8

# Session security (production settings)
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=lax

# Multi-factor authentication
MFA_ENABLED=false
OTP_ENABLED=false

# Access control
RBAC_ENABLED=false
ABAC_ENABLED=false

# Audit and sensitive data
AUDIT_LOG_ENABLED=false
LOG_SENSITIVE_DATA=false
EXPOSE_STACK_TRACES=false

# ============================================================
# Authentication Middleware (Advanced)
# ============================================================

# Auth mode: trust | jwt | apikey | oauth | mixed
COGNIMESH_AUTH_MODE=trust

# JWT configuration
COGNIMESH_AUTH_SECRET=
COGNIMESH_AUTH_SECRET_FILE=
COGNIMESH_AUTH_ALGORITHM=HS256
COGNIMESH_AUTH_ISSUER=cognimesh
COGNIMESH_AUTH_AUDIENCE=cognimesh-users
COGNIMESH_TOKEN_LIFETIME=3600
COGNIMESH_REFRESH_LIFETIME=604800

# RSA/EC keys for asymmetric algorithms
COGNIMESH_AUTH_PRIVATE_KEY=
COGNIMESH_AUTH_PRIVATE_KEY_FILE=
COGNIMESH_AUTH_PUBLIC_KEY=
COGNIMESH_AUTH_PUBLIC_KEY_FILE=

# Auto-generate secrets (not recommended for production)
COGNIMESH_AUTH_AUTO_GENERATE=false

# Auth-specific rate limits
COGNIMESH_RATE_LIMIT_JWT=100
COGNIMESH_RATE_LIMIT_APIKEY=1000
COGNIMESH_RATE_LIMIT_OAUTH=100
COGNIMESH_RATE_LIMIT_SESSION=100
COGNIMESH_RATE_LIMIT_WINDOW=900

# ============================================================
# Feature Flags
# ============================================================

FEATURE_TASKS=true
FEATURE_ROADMAPS=true
FEATURE_CLAUDE=true
FEATURE_WEBSOCKET=true
FEATURE_BATCH=true
FEATURE_STREAMING=true
FEATURE_DASHBOARD=true
FEATURE_ANALYTICS=true

# ============================================================
# Integrations
# ============================================================

# Webhook secret for external integrations
WEBHOOK_SECRET=default-secret-change-in-production

# API base URL for dashboard connections
API_BASE_URL=http://localhost:8080

# CORS origin for dashboard
CORS_ORIGIN=true

# ============================================================
# External Services (Optional)
# ============================================================

# Redis (if used for caching/sessions)
# REDIS_URL=redis://localhost:6379

# ============================================================
# Development/Debug
# ============================================================

# Node.js inspect mode (development only)
# NODE_OPTIONS=--inspect

# Temporary directory override
# TMPDIR=/tmp
# TEMP=/tmp

# ============================================================
# Quick Reference - Critical Variables
# ============================================================
# These variables MUST be configured for system operation:
#
# GITHUB_TOKEN=ghp_your_token_here
# BIOS_MODE=OPERATIONAL
# AUTO_UPDATE=true
# LOG_LEVEL=INFO
# DATABASE_PATH=./data/cognimesh.db
# COGNIMESH_PORT=3000
# JWT_SECRET=your_jwt_secret_here_change_in_production_minimum_32_chars
# STATE_PATH=./state
#
# API keys (ANTHROPIC_API_KEY, OPENAI_API_KEY, KIMI_API_KEY) are NOT
# required for subscription mode. They are only needed for testing.
#
# See full documentation above for all configuration options.
# ============================================================

# ============================================================
# NOTES
# ============================================================
# 1. All keys marked "change in production" MUST be changed
# 2. Never commit the actual .env file to git
# 3. In production, use a secrets manager (Vault, AWS Secrets, etc.)
# 4. Boolean values: true | false (case-insensitive in most cases)
# 5. Time durations: use ms for milliseconds or standard formats (1h, 30m)
# ============================================================
