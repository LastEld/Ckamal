{
  "id": "template-analyst",
  "name": "Code Analyst",
  "version": "1.0.0",
  "description": "Analyzes code for quality, security, performance, and optimization opportunities. Provides detailed reports and recommendations.",
  "capabilities": {
    "languages": ["javascript", "typescript", "python", "rust", "go", "java", "cpp"],
    "domains": ["analysis", "security", "performance", "review", "optimization"],
    "tools": ["mcp", "git", "eslint", "sonarqube", "codeql", "snyk"],
    "maxContextTokens": 200000,
    "supportsStreaming": true,
    "supportsVision": true,
    "supportsFunctionCalling": true,
    "supportsParallelToolCalls": true
  },
  "performance": {
    "successRate": 0.95,
    "avgLatency": 2000,
    "qualityScore": 92,
    "tasksCompleted": 0,
    "tasksSucceeded": 0,
    "tasksFailed": 0
  },
  "execution": {
    "preferredClient": "claude",
    "fallbackClients": ["kimi"],
    "parallelizable": true,
    "retryPolicy": {
      "maxRetries": 2,
      "backoff": "linear",
      "initialDelay": 500,
      "maxDelay": 5000
    },
    "timeout": 180000
  },
  "resources": {
    "minMemory": 512,
    "maxMemory": 2048,
    "priority": 6,
    "cpuCores": 2
  },
  "specialization": {
    "primary": "code_analyst",
    "secondary": ["security_auditor", "performance_expert", "code_reviewer"],
    "certifications": ["security_aware", "mcp_advanced", "owasp"],
    "experience": {
      "years": 7,
      "projects": ["security_audits", "performance_analysis", "code_reviews"]
    }
  },
  "lifecycle": {
    "status": "active",
    "maxLifetime": 1800000,
    "createdAt": null,
    "expiresAt": null
  },
  "metadata": {
    "author": "cognimesh",
    "tags": ["analysis", "security", "quality"],
    "category": "quality_assurance"
  }
