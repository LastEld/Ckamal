# CogniMesh v5.0 - Minimal Configuration
# Copy this to .env and customize for your setup
# Full options: see .env.example

# ============================================================
# Essential: Server Settings
# ============================================================

# Node environment: development | production
NODE_ENV=development

# Main server port (REST API)
COGNIMESH_PORT=3000

# Dashboard web interface port
DASHBOARD_PORT=3001

# ============================================================
# Essential: AI Client Features
# ============================================================

# Enable clients you have installed (uses your existing subscriptions)
# No API keys needed!
FEATURE_CLAUDE=true      # Claude Code/CLI users
FEATURE_CODEX=true       # Codex CLI users  
FEATURE_KIMI=true        # Kimi CLI users

# ============================================================
# Essential: GitHub Integration
# ============================================================

# GitHub Personal Access Token
# Get yours at: https://github.com/settings/tokens
# Required scopes: repo, workflow, read:org
GITHUB_TOKEN=ghp_your_token_here

# Your default repository (format: owner/repo)
GITHUB_REPO=yourusername/yourrepo

# ============================================================
# Essential: Security (Change these!)
# ============================================================

# Generate strong secrets (run: openssl rand -base64 48)
JWT_SECRET=change_this_to_a_random_string_min_32_chars_long
SESSION_SECRET=change_this_to_a_different_random_string_min_32

# Dashboard admin password (change in production!)
ADMIN_PASSWORD=admin

# ============================================================
# Optional: Database Location
# ============================================================

# SQLite database path (default is fine for most setups)
DATABASE_PATH=./data/cognimesh.db
